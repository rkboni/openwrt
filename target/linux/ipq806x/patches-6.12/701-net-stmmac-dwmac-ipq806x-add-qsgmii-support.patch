+/*
+ * Configure QSGMII PCS for a specific channel
+ * Based on NSS GMAC driver qsgmii_pcs_init()
+ */
+static int ipq806x_gmac_configure_qsgmii_channel(struct ipq806x_gmac *gmac)
+{
+	struct device *dev = &gmac->pdev->dev;
+	u32 val, val_readback;
+	int ret;
+
+	if (gmac->phy_mode != PHY_INTERFACE_MODE_QSGMII)
+		return 0;
+
+	if (gmac->id != 0) /* only gmac0 sets this up */
+		return 0;
+
+	regmap_read(gmac->qsgmii_csr, QSGMII_PCS_ALL_CH_CTL, &val);
+
+	if (val != 0 && val != 0xf) {
+		dev_info(dev, "GMAC%d: QSGMII already configured (0x%08x), not touching\n",
+		         gmac->id, val);
+		return 0;
+	}
+
+	dev_dbg(dev, "Configuring QSGMII PCS channel for GMAC%d\n", gmac->id);
+
+	/* Enable this QSGMII channel */
+	dev_info(dev, "GMAC%d: ALL_CH_CTL before enable: 0x%08x\n", gmac->id, val);
+
+	val |= QSGMII_PCS_ALL_CH_CTL_CH_EN(gmac->id);
+	regmap_write(gmac->qsgmii_csr, QSGMII_PCS_ALL_CH_CTL, val);
+
+	/* READ BACK to verify the write succeeded */
+	regmap_read(gmac->qsgmii_csr, QSGMII_PCS_ALL_CH_CTL, &val_readback);
+	dev_info(dev, "GMAC%d: ALL_CH_CTL after enable: 0x%08x (wrote 0x%08x)\n",
+	         gmac->id, val_readback, val);
+
+	/* Check if write failed */
+	if (val_readback == 0xf000aaaa) {
+		dev_err(dev, "GMAC%d: QSGMII register write FAILED! (regmap issue?)\n", gmac->id);
+		/* Try to continue anyway */
+	}
+
+	usleep_range(1000, 2000);
+
+	/* Read current calibration state */
+	regmap_read(gmac->qsgmii_csr, QSGMII_PCS_CAL_LCKDT_CTL, &val);
+	dev_dbg(dev, "CAL_LCKDT_CTL initial: 0x%08x\n", val);
+
+	/* Release reset if asserted, preserving other bits */
+	if (val & QSGMII_PCS_CAL_LCKDT_CTL_RST) {
+		val &= ~QSGMII_PCS_CAL_LCKDT_CTL_RST;
+		regmap_write(gmac->qsgmii_csr, QSGMII_PCS_CAL_LCKDT_CTL, val);
+		usleep_range(1000, 2000);
+		regmap_read(gmac->qsgmii_csr, QSGMII_PCS_CAL_LCKDT_CTL, &val);
+	}
+
+	/* Already locked - nothing to do */
+	if (val & QSGMII_PCS_CAL_LCKDT_CTL_LCKDT) {
+		dev_dbg(dev, "QSGMII PCS channel %d already locked\n", gmac->id);
+		return 0;
+	}
+
+ 	/* Enable autoneg for this channel */
+ 	regmap_read(gmac->qsgmii_csr, QSGMII_PCS_MODE_CTL, &val);
+ 	val |= QSGMII_PCS_MODE_CTL_AUTONEG_EN(gmac->id);
+ 	regmap_write(gmac->qsgmii_csr, QSGMII_PCS_MODE_CTL, val);
+ 	dev_info(dev, "Set MODE_CTL: 0x%08x\n", val);
+
+	usleep_range(10000, 20000);
+
+ 	/* Wait for calibration lock */
+ 	ret = regmap_read_poll_timeout(gmac->qsgmii_csr,
+ 					   QSGMII_PCS_CAL_LCKDT_CTL, val,
+ 					   val & QSGMII_PCS_CAL_LCKDT_CTL_LCKDT,
+ 					   1000, 200000);
+
+ 	regmap_read(gmac->qsgmii_csr, QSGMII_PCS_CAL_LCKDT_CTL, &val);
+ 	dev_info(dev, "Final CAL_LCKDT_CTL: 0x%08x (%s)\n",
+ 		 val, ret ? "timeout" : "locked");
+
+ 	if (ret)
+ 		dev_warn(dev, "Continuing despite calibration timeout\n");
+
+	return 0;	/* Always continue - hardware may work anyway */
+}
